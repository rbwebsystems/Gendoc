rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Hər istifadəçi yalnız öz qovluğunu oxuyub-yaza bilər
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
